# RPC + chain (Base Sepolia)
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Wallets - generated by scripts/fund-wallets.js; never commit real values
CREATOR_MNEMONIC=twelve words generated by fund-wallets
JOINER_MNEMONIC=twelve words generated by fund-wallets
JUROR1_MNEMONIC=twelve words generated by fund-wallets
JUROR2_MNEMONIC=twelve words generated by fund-wallets
JUROR3_MNEMONIC=twelve words generated by fund-wallets

# Contracts - written by scripts/deploy.js
USDT_CONTRACT=0x...
ESCROW_CONTRACT=0x...

# EIP-3009 gasless path - written by scripts/deploy-puntusdt.cjs
PUNTUSDT_CONTRACT=0x...
# Set to 1 to route join stakes through the facilitator
PUNT_GASLESS=0
PUNT_FACILITATOR_URL=http://127.0.0.1:9780
# Sponsor wallet for scripts/facilitator.js (pays gas for joiners)
FACILITATOR_MNEMONIC=twelve words for the gas sponsor

# Feed bootstrap key - written by the first peer on boot
FEED_KEY=hex-written-automatically
FEED_SECRET=hex-written-automatically

# Optional: separate DHT topic for jurors (set to 1 to enable blind-peering)
# PUNT_JUROR_POOL=1

# Official results - free key from https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your-key-here
