{
  "name": "punt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "P2P swipe-to-stake football bets — no bookmaker, no server, no oracle. Autobase feed + QVAC LLM jury + WDK USDT escrow.",
  "license": "MIT",
  "workspaces": [
    "packages/shared",
    "packages/feed",
    "packages/relay",
    "packages/juror",
    "packages/app"
  ],
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "require-addon": "1.2.0",
    "rocksdb-native": "3.16.0"
  },
  "scripts": {
    "test": "node --test \"tests/*.test.js\"",
    "coverage": "c8 --reporter=text --reporter=lcov --include=\"packages/**\" --include=\"scripts/**\" node --test \"tests/*.test.js\"",
    "compile": "node scripts/compile.js",
    "jury:demo": "node scripts/jury-demo.js",
    "relay": "node packages/relay/relay.js",
    "juror": "node packages/juror/index.js",
    "deploy-contracts": "node scripts/deploy.js",
    "fund-wallets": "node scripts/fund-wallets.js",
    "demo": "bash scripts/demo.sh",
    "peer:creator": "PUNT_ROLE=CREATOR PUNT_UI_PORT=9701 PUNT_FEED_LISTEN=9471 node packages/app/peer.js",
    "peer:joiner": "PUNT_ROLE=JOINER PUNT_UI_PORT=9702 PUNT_FEED_CONNECT=127.0.0.1:9471 node packages/app/peer.js",
    "app:creator": "PUNT_ROLE=CREATOR PUNT_UI_PORT=9701 electron packages/app/main.cjs",
    "app:joiner": "PUNT_ROLE=JOINER PUNT_UI_PORT=9702 electron packages/app/main.cjs",
    "juror1": "PUNT_JUROR=1 node packages/juror/index.js",
    "juror2": "PUNT_JUROR=2 node packages/juror/index.js",
    "juror3": "PUNT_JUROR=3 node packages/juror/index.js"
  },
  "dependencies": {
    "@qvac/sdk": "^0.13.5",
    "@tetherto/wdk-wallet": "^1.0.0-beta.11",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.13",
    "autobase": "^7.28.1",
    "corestore": "^7.11.0",
    "hyperbee": "^2.24.2",
    "hypercore-crypto": "^3.7.0",
    "hyperswarm": "^4.17.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "electron": "^43.0.0",
    "ethers": "^6.13.0",
    "solc": "^0.8.26"
  }
}
